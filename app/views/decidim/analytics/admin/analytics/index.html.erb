<div class="card" id="analytics">
  <div class="card-divider">
    <h2 class="card-title">
        <%= t "decidim.admin.title.analytics" %>
    </h2>
  </div>
  <div class="card-section">
    <iframe
      src="<%= @iframe_url %>"
      frameborder="0"
      marginheight="0"
      marginwidth="0"
      width="100%"
      height="4200px"
      allowtransparency
    ></iframe>
  </div>
</div>


